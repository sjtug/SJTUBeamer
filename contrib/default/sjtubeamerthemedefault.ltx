\ProvidesFile{sjtubeamerthemedefault.ltx}[2026/03/05 Default theme for SJTUBeamer]

% 标题页
\setbeamertemplate{title page}[default][]

%% 底页
\setbeamertemplate{bottom page}{
  \begin{center}
    \Large\bottomthanks
  \end{center}
}

% 恢复原始节次页设置
\setbeamertemplate{part page}[default]
\setbeamertemplate{section page}[default]
\setbeamertemplate{subsection page}[default]

% 部分页带徽标
\AtBeginPart{
  \begin{frame}
    \partpage
  \end{frame}
}

%% 清空背景
\setbeamertemplate{background}{}

%% 清空标题图像
\titlegraphic{}

%% 清空 logo
% \logo{}

%% 不显示导航符号，只显示页码
\setbeamertemplate{navigation symbols}{
  \hbox{
    \raisebox{1.2pt}[0pt][0pt]{
      \usebeamerfont{footline}
      \usebeamercolor{footline}
      \color{footline.fg!50}
      \insertframenumber/\inserttotalframenumber
      \hspace*{0.2em}
    }
  }
}

% 颜色设置
\setbeamercolor{title}{fg=cprimary}
\setbeamercolor{subtitle}{fg=csecondary}
\setbeamercolor{author}{bg=,fg=black}
\setbeamercolor{institute}{parent=author}
\setbeamercolor{date}{parent=author}
